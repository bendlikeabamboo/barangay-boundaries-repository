<https://psgc.gov.ph/event/2026-04-13/0001> a org:ChangeEvent ;
    dct:date "2026-04-13"^^xsd:date ;
    dct:description "Corrected name from Sanchez-Mira to Sanchez Mira"@en ;
    dct:source """1. Certification signed by the Municipal Mayor with the following supporting documents:
a. Ereccion de los Pueblos de Cagayan 1863-1898 Tomo VII, provided by the National Archives of the Philippines to the said municipality;
b. Census of the Philippine Islands: 1903, Volume Two;
c. RA 7809 dated 16 September 1994;
d. Sangguniang Bayan Resolution No. 2026-12-058, dated 09 February 2026;
e. The Biography of General Manuel Sanchez Mira

2. Letter of the NHCP recommending the use of the barangay’s name based on historical records, dated 06 February 2025."""@en ;
    org:classification <https://psgc.gov.ph/concept/change-type/renaming> ;
    org:originalOrganization <https://psgc.gov.ph/entity/0201522000> ;
    org:resultingOrganization <https://psgc.gov.ph/entity/0201522000> ;
    prov:generatedAtTime "2026-03-28"^^xsd:date .

