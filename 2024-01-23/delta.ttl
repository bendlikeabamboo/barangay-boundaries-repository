<https://psgc.gov.ph/event/2024-01-23/0000> a org:ChangeEvent ;
    dct:date "2024-01-23"^^xsd:date ;
    dct:description "Luna (City of Iloilo) renamed to Luna (Jaro)"@en ;
    dct:source "PSA Press Release: No Change in the Fourth Quarter 2023 PSGC - district descriptors added to 11 barangays in City of Iloilo to differentiate those sharing identical names; PSA states this does not constitute a name change but is additional information indicating the district where the barangay is situated"@en ;
    org:classification <https://psgc.gov.ph/concept/change-type/name_correction> ;
    org:resultingOrganization <https://psgc.gov.ph/entity/0631000097> .

